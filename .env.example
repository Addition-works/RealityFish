# ===== LLM API (OpenAI SDK-compatible endpoint) =====
# Any provider that exposes an OpenAI-compatible /v1/chat/completions works.
# Note: simulations are token-intensive — start with < 40 rounds.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=claude-sonnet-4-6

# ===== Zep Cloud (knowledge graph) =====
# Free monthly quota is sufficient for light usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Social Media Scraping (RealityFish) =====
# Apify — X/Twitter scraping (https://apify.com/)
APIFY_API_TOKEN=your_apify_token_here

# Reddit API via PRAW (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=realityfish-bot/1.0

# ===== Optional: Boost LLM (separate model for heavy tasks) =====
# Omit these entirely if not using a secondary model.
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Optional: RealityFish tuning =====
# OASIS_DEFAULT_MAX_ROUNDS=10
# FOCUS_GROUPS_ENABLED=true
# AWARENESS_BASE_PROBABILITY=0.15
# TOPIC_AWARE_BOOST=0.6
